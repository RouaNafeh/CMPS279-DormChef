<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:gravity="top"
    android:orientation="horizontal">

    <TextView
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_create_row_badge"
        android:gravity="center"
        android:text="•"
        android:textColor="@color/chip_text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/ModernInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etStepInstruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:padding="12dp"
                android:textColor="@color/textDark"
                android:textColorHint="@color/textGrey"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/ModernInputLayout"
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/step_time_label">

            <EditText
                android:id="@+id/etStepMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:inputType="number"
                android:maxLines="1"
                android:padding="12dp"
                android:textColor="@color/textDark"
                android:textColorHint="@color/textGrey"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <ImageButton
        android:id="@+id/btnDeleteStepRow"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_create_icon_button"
        android:contentDescription="Remove"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/textGrey" />

</LinearLayout>
