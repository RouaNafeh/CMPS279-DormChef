<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="2dp"
    app:cardBackgroundColor="@color/card_white"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/borderSoft"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/food_img"
            android:layout_width="98dp"
            android:layout_height="98dp"
            android:scaleType="centerCrop"
            android:src="@drawable/salad"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/RoundedImageView" />

        <TextView
            android:id="@+id/recipe_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:text="Recipe name"
            android:textColor="@color/textDark"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/heart"
            app:layout_constraintStart_toEndOf="@id/food_img"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/heart"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/search_background"
            android:contentDescription="Favorite"
            android:padding="11dp"
            android:scaleType="fitCenter"
            android:src="@drawable/heart"
            app:layout_constraintBottom_toBottomOf="@id/recipe_name"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/recipe_name" />

        <LinearLayout
            android:id="@+id/time_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/search_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            app:layout_constraintStart_toStartOf="@id/recipe_name"
            app:layout_constraintTop_toBottomOf="@id/recipe_name">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="time"
                android:src="@drawable/baseline_access_time_24"
                app:tint="@color/primary" />

            <TextView
                android:id="@+id/recipe_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="15 min"
                android:textColor="@color/textGrey"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/budget_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/search_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="6dp"
            android:paddingEnd="10dp"
            android:paddingBottom="6dp"
            app:layout_constraintStart_toEndOf="@id/time_row"
            app:layout_constraintTop_toBottomOf="@id/recipe_name">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="budget"
                android:src="@drawable/payment"
                app:tint="@color/accent_pink" />

            <TextView
                android:id="@+id/recipe_budget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Low"
                android:textColor="@color/textGrey"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/tag_background"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="None"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/recipe_name"
            app:layout_constraintTop_toBottomOf="@id/time_row" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
