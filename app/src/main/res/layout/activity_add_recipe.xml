<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secondary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="48dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_back_button"
                    android:contentDescription="Back"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/textDark" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:fontFamily="@font/genty_sans_regular"
                    android:text="Add Recipe"
                    android:textColor="@color/textDark"
                    android:textSize="26sp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/borderSoft"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        style="@style/FilterSectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recipe details" />

                    <TextView
                        style="@style/FilterSectionHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="14dp"
                        android:text="Pick a photo and add one ingredient and one step per line." />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivSelectedPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:contentDescription="@string/recipe_detail_image"
                        android:scaleType="centerCrop"
                        android:src="@drawable/logo_cropped"
                        app:shapeAppearanceOverlay="@style/RoundedImageView" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickPhoto"
                        style="@style/ModernSecondaryButton"
                        android:layout_width="match_parent"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="10dp"
                        android:text="Choose Photo"
                        />

                    <EditText
                        android:id="@+id/etRecipeName"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/search_background"
                        android:gravity="center_vertical"
                        android:hint="Recipe name"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/textDark"
                        android:textColorHint="@color/textGrey" />

                    <EditText
                        android:id="@+id/etRecipeTime"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/search_background"
                        android:gravity="center_vertical"
                        android:hint="Time in minutes"
                        android:inputType="number"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/textDark"
                        android:textColorHint="@color/textGrey" />

                    <EditText
                        android:id="@+id/etRecipeBudget"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/search_background"
                        android:gravity="center_vertical"
                        android:hint="Budget"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/textDark"
                        android:textColorHint="@color/textGrey" />

                    <EditText
                        android:id="@+id/etRecipeEquipment"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/search_background"
                        android:gravity="center_vertical"
                        android:hint="Equipment"
                        android:paddingHorizontal="14dp"
                        android:textColor="@color/textDark"
                        android:textColorHint="@color/textGrey" />

                    <EditText
                        android:id="@+id/etRecipeIngredients"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        android:layout_marginBottom="10dp"
                        android:background="@drawable/search_background"
                        android:gravity="top|start"
                        android:hint="Ingredients, one per line"
                        android:inputType="textMultiLine"
                        android:padding="14dp"
                        android:textColor="@color/textDark"
                        android:textColorHint="@color/textGrey" />

                    <EditText
                        android:id="@+id/etRecipeSteps"
                        android:layout_width="match_parent"
                        android:layout_height="130dp"
                        android:layout_marginBottom="14dp"
                        android:background="@drawable/search_background"
                        android:gravity="top|start"
                        android:hint="Steps, one per line"
                        android:inputType="textMultiLine"
                        android:padding="14dp"
                        android:textColor="@color/textDark"
                        android:textColorHint="@color/textGrey" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddRecipe"
                        style="@style/ModernPrimaryButton"
                        android:layout_width="match_parent"
                        android:text="Save Recipe"
                        />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
