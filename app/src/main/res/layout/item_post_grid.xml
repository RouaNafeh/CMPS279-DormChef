<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="3dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="2dp"
    app:cardBackgroundColor="@color/card_white"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/borderSoft"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="152dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/post_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/salad"
                app:shapeAppearanceOverlay="@style/RoundedImageView" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_delete"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:background="@drawable/search_background"
                android:contentDescription="More actions"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_more_vert" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_save"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btn_like"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/likes_count"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="26dp"
                    android:layout_height="26dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/post_avatar_image"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_avatar_clip"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/RoundedImageView" />

                    <TextView
                        android:id="@+id/post_avatar"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_profile_avatar"
                        android:gravity="center"
                        android:text="C"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <TextView
                    android:id="@+id/post_username"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:ellipsize="end"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:text="by Chef"
                    android:textColor="@color/textGrey"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/post_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="7dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Post title"
                android:textColor="@color/textDark"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/post_description"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/post_time"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/post_budget"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
